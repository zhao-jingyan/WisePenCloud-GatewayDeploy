# =============================================================================
# .env 样例
# -----------------------------------------------------------------------------
# 用法：
#   cp .env.example .env
# =============================================================================

# APISIX Admin API
APISIX_ADMIN_HOST=apisix
APISIX_ADMIN_PORT=9180

# APISIX Admin Key
APISIX_ADMIN_KEY=edd1c9f034335f136f87ad84b625c8f1

# Redis（auth.lua使用此密钥从 Redis 获取用户登录凭据）
REDIS_AUTH_PASSWORD=root

# 服务间安全（APISIX与后端服务的安全切口）
# 与 wisepen-cloud / wisepen-cloud-ai / wisepen-cloud-sidecar 共用
# 生产部署务必改为高强度随机串
FROM_SOURCE_SECRET=APISIX-wX0iR6tY

# CORS 正则（可选）
# 留空时 setup.sh 会读 defaults/cors-allow-origins.json
# CORS_REGEX_JSON='["^https?://localhost(:\\d+)?$"]'
